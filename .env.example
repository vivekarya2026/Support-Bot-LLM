# Optional env fallbacks — all of these are normally set in /admin/settings
# (stored in data/vectors.db). Env values are only used when no setting exists.

# Get your key at https://openrouter.ai/keys (or any OpenAI-compatible provider)
OPENROUTER_API_KEY=

# Override to point at another OpenAI-compatible endpoint.
# Leave unset to use https://openrouter.ai/api/v1.
OPENROUTER_BASE_URL=

# Optional: shown to OpenRouter for attribution / rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SupportKit

# Optional: Tavily key for the per-bot Social Listening pages
TAVILY_API_KEY=

# Voice module: URL of the local voice sidecar (see voice-service/README.md).
# Leave unset to use http://127.0.0.1:8078; set empty in /admin/settings to
# disable voice everywhere. Start the sidecar with `npm run dev:voice`
# (or run both processes together with `npm run dev:all`).
VOICE_SERVICE_URL=
